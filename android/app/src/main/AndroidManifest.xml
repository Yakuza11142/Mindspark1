<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://android.com"
    xmlns:tools="http://android.com"
    package="com.example.mindspark">

    <!-- Forces the compiler to replace any broken dependency definitions with your valid keys -->
    <uses-permission android:name="android.permission.INTERNET" tools:node="replace"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" tools:node="replace"/>
    <uses-permission android:name="android.permission.WAKE_LOCK" tools:node="replace"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" tools:node="replace"/>
    <uses-permission android:name="android.permission.VIBRATE" tools:node="replace"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" tools:node="replace"/>
    <uses-permission android:name="android.permission.CAMERA" tools:node="replace"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO" tools:node="replace"/>
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="replace"/>

    <uses-feature android:name="android.hardware.camera" android:required="false" tools:node="replace"/>
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" tools:node="replace"/>
    <uses-feature android:name="android.hardware.camera.ar" android:required="true" tools:node="replace"/>

    <queries tools:node="replace">
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <category android:name="android.intent.category.BROWSABLE"/>
            <data android:scheme="https"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <category android:name="android.intent.category.BROWSABLE"/>
            <data android:scheme="http"/>
        </intent>
    </queries>

    <application
        android:name="androidx.multidex.MultiDexApplication"
        android:label="Mind Spark"
        android:icon="@android:drawable/sym_def_app_icon"
        android:allowBackup="true"
        android:fullBackupContent="true"
        android:hardwareAccelerated="true"
        tools:targetApi="34"
        tools:node="merge">

        <meta-data android:name="com.google.android.gms.ads.APPLICATION_ID" android:value="ca-app-pub-0000000000000000~0000000000000000" tools:node="replace"/>
        <meta-data android:name="com.google.ar.core" android:value="required" tools:node="replace"/>
        <meta-data android:name="flutter_deeplinking_enabled" android:value="true" tools:node="replace"/>
        <meta-data android:name="flutterEmbedding" android:value="2" tools:node="replace"/>

        <activity
            android:name="io.flutter.embedding.android.FlutterActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            tools:node="replace">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
