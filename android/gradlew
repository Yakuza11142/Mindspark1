#!/usr/bin/env sh

# Ensure we use an absolute path for resolving the script location
# to handle execution relative paths accurately
DIRNAME=$(dirname "$0")
[ -z "$DIRNAME" ] && DIRNAME="."
APP_BASE_NAME=$(basename "$0")
APP_HOME=$(cd "$DIRNAME" && pwd)

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Locate standard system paths
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

if [ ! -x "$JAVACMD" ] ; then
    die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME"
fi

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Collect execution arguments safely
for arg do
    # Escape characters for execution arrays
    case $arg in
        (-*) ;;
        (*) arg="\"$arg\"" ;;
    esac
    ARGS="$ARGS $arg"
done

# Execute the core Java wrapper logic mapping properties targets
exec "$JAVACMD" \
    "-Dorg.gradle.appname=$APP_BASE_NAME" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
