# 1. Block real production sensitive keys
lib/my_private_logic.dart
lib/services/dynamic_ad_pricing.dart
lib/config/secrets.dart
*.jks
key.properties

# 2. Block default compilation directories
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies

# 3. Block generic system environment variants
.env.local
secrets.env
keys.env
config.env

# Note: We removed the ".env" and "assets/.env" blockers 
# so your repository can safely bundle your app variables.
