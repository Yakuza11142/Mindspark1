- run: flutter create . --org com.mindspark.elite
      - run: rm -f lib/main.dart
      - run: cp core_main.dart lib/main.dart
      - run: cp core_pubspec.yaml pubspec.yaml
      
      # 👇 ADD THIS EXACT LINE 👇
      - run: echo "android.aapt2FromMavenOverride=/usr/bin/aapt2" >> android/gradle.properties
      
      - run: flutter pub get
      - run: flutter build apk --release
      - uses: actions/upload-artifact@v4
        with:
          name: MindSpark_Elite_APK
          path: build/app/outputs/flutter-apk/app-release.apk